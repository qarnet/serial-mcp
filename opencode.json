{
  "$schema": "https://opencode.ai/config.json",
  "snapshot": false,
  "watcher": {
    "ignore": [
      ".git/**",
      ".direnv/**",
      "build/**",
      "target/**"
    ]
  },
  "lsp": {
    "clangd": {
      "command": [
        "direnv",
        "exec",
        ".",
        "clangd",
        "--query-driver=/nix/store/*/bin/*"
      ],
      "extensions": [
        "c",
        "h"
      ]
    }
  },
  "mcp": {
    "serial-mcp": {
      "type": "local",
      "command": [
        "./scripts/opencode-mcp-clean-env",
        "nix",
        "run",
        ".#serial-mcp-dev",
        "--",
        "--allowlist=/dev/ttyACM*,/dev/ttyUSB*,/dev/pts/*"
      ],
      "enabled": true
    },
    "searxng": {
      "type": "local",
      "command": [
        "./scripts/opencode-mcp-clean-env",
        "npx",
        "-y",
        "mcp-searxng@v1.0.5"
      ],
      "environment": {
        "SEARXNG_URL": "https://search.lan.karnetvr.com/"
      },
      "enabled": true
    },
    "nordic-semiconductor-docs": {
      "enabled": true
    },
    "zephyr-docs": {
      "enabled": true
    }
  }
}

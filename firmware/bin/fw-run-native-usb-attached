#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
#
# Run the USB-enabled `native_sim` test firmware via USB/IP.
#
# Variant build dir: build/native_sim_usb
# Resulting binary:  build/native_sim_usb/firmware/zephyr/zephyr.exe
#
# Starts zephyr.exe, waits for local USB/IP export on 127.0.0.1:3241,
# attaches it, prints /dev/ttyACMx, then detaches on exit.
#
# Override the build dir by exporting SERIAL_MCP_FW_BUILD_DIR.
# Override the binary by exporting SERIAL_MCP_NATIVE_SIM_USB_BIN.

set -euo pipefail

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=firmware/bin/fw-common.sh
source "$SCRIPT_DIR/fw-common.sh"

DEFAULT_BUILD_DIR="${SERIAL_MCP_FW_BUILD_DIR:-$(_fw_repo_dir)/build/native_sim_usb}"
EXE_PATH="${SERIAL_MCP_NATIVE_SIM_USB_BIN:-$DEFAULT_BUILD_DIR/firmware/zephyr/zephyr.exe}"
CONFIG_PATH="$DEFAULT_BUILD_DIR/firmware/zephyr/.config"
USBIP_PORT="${SERIAL_MCP_USBIP_PORT:-3241}"
USBIP_HOST="${SERIAL_MCP_USBIP_HOST:-127.0.0.1}"
ATTACHED_BUSID=""
FW_PID=""

resolve_cmd() {
  local cmd
  cmd="$1"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    return 1
  fi
  readlink -f "$(command -v "$cmd")"
}

list_tty_acm() {
  local dev found=1
  for dev in /dev/ttyACM*; do
    if [ -e "$dev" ]; then
      printf '%s\n' "$dev"
      found=0
    fi
  done
  return "$found"
}

cleanup() {
  local status=$?

  if [ -n "$ATTACHED_BUSID" ]; then
    local port
    port="$({ usbip port 2>/dev/null || true; } | awk -v target="usbip://$USBIP_HOST:$USBIP_PORT/$ATTACHED_BUSID" '
      $1 == "Port" { gsub(":", "", $2); current=$2 }
      index($0, target) { print current; exit }
    ')"
    if [ -n "$port" ]; then
      if [ "$USBIP_HOST" = "127.0.0.1" ] && [ "$USBIP_PORT" = "3241" ] && usbip_native_sim_detach_cmd="$(resolve_cmd usbip-native-sim-detach 2>/dev/null)"; then
        sudo -n "$usbip_native_sim_detach_cmd" "$port" >/dev/null 2>&1 || true
      else
        usbip --tcp-port "$USBIP_PORT" detach -p "$port" >/dev/null 2>&1 || true
      fi
    fi
  fi

  if [ -n "$FW_PID" ]; then
    kill "$FW_PID" >/dev/null 2>&1 || true
    wait "$FW_PID" >/dev/null 2>&1 || true
  fi

  exit "$status"
}

if [ ! -x "$EXE_PATH" ]; then
  printf 'Missing native_sim USB binary: %s\n' "$EXE_PATH" >&2
  printf 'Build first. Example: fw-build-native-usb\n' >&2
  exit 1
fi

if [ ! -f "$CONFIG_PATH" ] || ! grep -q '^CONFIG_USB_DEVICE_STACK=y' "$CONFIG_PATH"; then
  printf 'Build missing native_sim USB config. Run: fw-build-native-usb\n' >&2
  exit 1
fi

if [ ! -d /sys/module/vhci_hcd ]; then
  if usbip_native_sim_load_vhci_cmd="$(resolve_cmd usbip-native-sim-load-vhci 2>/dev/null)"; then
    sudo -n "$usbip_native_sim_load_vhci_cmd"
  else
    printf 'Missing vhci_hcd module. Load first: sudo modprobe vhci_hcd\n' >&2
    exit 1
  fi
fi

if ! command -v usbip >/dev/null 2>&1; then
  printf 'Missing usbip tool in PATH\n' >&2
  exit 1
fi

before_acm="$(list_tty_acm 2>/dev/null | tr '\n' ' ' || true)"

trap cleanup EXIT INT TERM

"$EXE_PATH" "$@" &
FW_PID=$!

remote_list=""
for _ in $(seq 1 50); do
  if remote_list="$(usbip --tcp-port "$USBIP_PORT" list -r "$USBIP_HOST" 2>/dev/null)" && [ -n "$remote_list" ]; then
    break
  fi
  if ! kill -0 "$FW_PID" >/dev/null 2>&1; then
    wait "$FW_PID"
    exit $?
  fi
  sleep 0.2
done

if [ -z "$remote_list" ]; then
  printf 'USB/IP server not visible at %s:%s\n' "$USBIP_HOST" "$USBIP_PORT" >&2
  exit 1
fi

ATTACHED_BUSID="$(printf '%s\n' "$remote_list" | grep -oP '^\s*\K[0-9]+-[0-9]+(\.[0-9]+)*(?=:)' | head -n1 || true)"

if [ -z "$ATTACHED_BUSID" ]; then
  printf 'No exported USB/IP busid found at %s:%s\n' "$USBIP_HOST" "$USBIP_PORT" >&2
  printf '%s\n' "$remote_list" >&2
  exit 1
fi

if [ "$USBIP_HOST" = "127.0.0.1" ] && [ "$USBIP_PORT" = "3241" ] && usbip_native_sim_attach_cmd="$(resolve_cmd usbip-native-sim-attach 2>/dev/null)"; then
  sudo -n "$usbip_native_sim_attach_cmd" "$ATTACHED_BUSID"
else
  usbip --tcp-port "$USBIP_PORT" attach -r "$USBIP_HOST" -b "$ATTACHED_BUSID"
fi

new_acm=""
for _ in $(seq 1 20); do
  after_acm="$(list_tty_acm 2>/dev/null | tr '\n' ' ' || true)"
  new_acm="$({
    for dev in $after_acm; do
      case " $before_acm " in
        *" $dev "*) ;;
        *) printf '%s\n' "$dev"; break ;;
      esac
    done
  } || true)"
  if [ -n "$new_acm" ]; then
    printf 'Attached %s via usbip://%s:%s/%s\n' "$new_acm" "$USBIP_HOST" "$USBIP_PORT" "$ATTACHED_BUSID"
    break
  fi
  sleep 0.2
done

if [ -z "$new_acm" ]; then
  printf 'Attached busid %s, but no new /dev/ttyACM* detected yet\n' "$ATTACHED_BUSID" >&2
fi

wait "$FW_PID"

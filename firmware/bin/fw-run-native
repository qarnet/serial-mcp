#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
#
# Run the plain `native_sim` test firmware.
#
# Variant build dir: build/native_sim
# Resulting binary:  build/native_sim/zephyr/zephyr.exe
#
# Override the build dir by exporting SERIAL_MCP_FW_BUILD_DIR.
# Override the binary path by exporting SERIAL_MCP_NATIVE_SIM_BIN.

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=firmware/bin/fw-common.sh
source "$SCRIPT_DIR/fw-common.sh"

DEFAULT_BUILD_DIR="${SERIAL_MCP_FW_BUILD_DIR:-$(_fw_repo_dir)/build/native_sim}"
EXE_PATH="${SERIAL_MCP_NATIVE_SIM_BIN:-$DEFAULT_BUILD_DIR/firmware/zephyr/zephyr.exe}"

if [ ! -x "$EXE_PATH" ]; then
  printf 'Missing native_sim binary: %s\n' "$EXE_PATH" >&2
  printf 'Build first. Example: fw-build-native\n' >&2
  exit 1
fi

exec "$EXE_PATH" "$@"

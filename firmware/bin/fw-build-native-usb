#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
#
# Build USB-enabled `native_sim` test firmware.
#
# Variant build dir: build/native_sim_usb
# Resulting binary:  build/native_sim_usb/firmware/zephyr/zephyr.exe
# Also emits:       build/native_sim_usb/firmware/compile_commands.json
#
# Plain and USB variants use separate build trees so they can never
# contaminate each other's Kconfig/devicetree state.
#
# Override the build dir by exporting SERIAL_MCP_FW_BUILD_DIR.

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=firmware/bin/fw-common.sh
source "$SCRIPT_DIR/fw-common.sh"

cd "$(_fw_repo_dir)"

BUILD_DIR="${SERIAL_MCP_FW_BUILD_DIR:-$(_fw_repo_dir)/build/native_sim_usb}"

exec west build -b native_sim firmware/ -d "$BUILD_DIR" --pristine -- \
  -DEXTRA_CONF_FILE=boards/native_sim_usb.conf \
  -DEXTRA_DTC_OVERLAY_FILE=boards/native_sim_usb.overlay \
  -DCMAKE_EXPORT_COMPILE_COMMANDS=ON \
  "$@"
